# ── Banco de dados ─────────────────────────────────────────────────────────
# Desenvolvimento: SQLite
DATABASE_URL=sqlite:///vies_detector.db
# Produção: MySQL
# DATABASE_URL=mysql+pymysql://user:password@host:3306/vies_detector

# ── Modelo ─────────────────────────────────────────────────────────────────
# Caminho local do modelo fine-tuned (após treinamento)
MODEL_PATH=models/bertimbau-bias
# Ou use o modelo base diretamente do HuggingFace (sem fine-tuning):
# MODEL_PATH=neuralmind/bert-base-portuguese-cased

# ── Pipeline ───────────────────────────────────────────────────────────────
COLLECT_INTERVAL_MINUTES=60
MAX_SNIPPET_CHARS=500
LOG_LEVEL=INFO

# ── API ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=false
