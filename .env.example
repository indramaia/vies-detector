# ── Banco de dados ─────────────────────────────────────────────────────────
# Desenvolvimento: SQLite
DATABASE_URL=sqlite:///vies_detector.db
# Produção: PostgreSQL Railway (Railway injeta DATABASE_URL automaticamente)
# DATABASE_URL=postgresql://user:pass@host:5432/railway

# ── CORS ───────────────────────────────────────────────────────────────────
# Domínio(s) do frontend separados por vírgula. Use * apenas em dev.
CORS_ORIGINS=https://biasradar.lovable.app

# ── API ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=false

# ── Pipeline (não usado pela API em produção) ───────────────────────────────
MODEL_PATH=models/bertimbau-bias
COLLECT_INTERVAL_MINUTES=60
MAX_SNIPPET_CHARS=500
LOG_LEVEL=INFO
